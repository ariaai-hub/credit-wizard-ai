{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "scripts/**/*.ts", "src/app/api/admin/**/*", "src/app/api/client/affiliate/**/*", "src/app/api/client/consumer-onboarding/**/*", "src/app/api/client/download-letter/**/*", "src/app/api/client/download-status/**/*", "src/app/api/client/elite-content/**/*", "src/app/dashboard/affiliate/**/*", "src/components/letters-section.tsx", "src/app/dashboard/elite-content/**/*"]
}
